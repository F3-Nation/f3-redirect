# Required: Your F3 region's slug on regions.f3nation.com
# Example: "muletown", "nashville", "churham"
REGION_SLUG=

# Required: Your F3 region's numeric ID (used for stats URL)
# Find this at pax-vault.f3nation.com — it's the number in /stats/region/<id>
REGION_ID=

# Required: Your F3 region's display name (used in page titles and metadata)
# Example: "Muletown", "Nashville", "Churham"
REGION_NAME=
