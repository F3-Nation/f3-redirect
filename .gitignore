# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# --- Go (redirect tier) ---
# Test binaries and build output
*.test
*.out
/bin/
/dist/
# Coverage
coverage.out
coverage.txt
coverage.html
profile.cov

# --- Node / TypeScript (frontend + API) ---
node_modules/
.pnp
.pnp.*
.pnpm-store/
package-lock.json
npm-shrinkwrap.json
yarn.lock
.next/
out/
build/
*.tsbuildinfo
next-env.d.ts
.eslintcache
.turbo

# --- Testing ---
coverage/
.nyc_output/
*.lcov
playwright-report/
test-results/
blob-report/

# --- Terraform / infra ---
.terraform/
*.tfstate
*.tfstate.*
*.tfplan
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
*.tfvars
*.tfvars.json
*.auto.tfvars
*.auto.tfvars.json
!**/*.tfvars.example

# --- Secrets / certs (never commit) ---
*.pem
*.key
*.crt
*.p12
*-key.json
service-account*.json

# --- Env files ---
.env*
!.env.example

# --- Misc / OS ---
.DS_Store
.cache/
.tmp/
tmp/
*.log
logs/
